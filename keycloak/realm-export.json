{
  "id": "valid-os",
  "realm": "valid-os",
  "displayName": "Valid OS",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "verifyEmail": false,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Default application user",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "valid-os-web",
      "name": "Valid OS Web",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "bearerOnly": false,
      "consentRequired": false,
      "frontchannelLogout": true,
      "redirectUris": ["http://localhost:5173/*"],
      "webOrigins": ["http://localhost:5173"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "audience-valid-os-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "valid-os-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "valid-os-api",
      "name": "Valid OS API",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "bearerOnly": true,
      "consentRequired": false,
      "frontchannelLogout": false,
      "redirectUris": [],
      "webOrigins": []
    }
  ],
  "users": [
    {
      "username": "admin@valid.local",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@valid.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    }
  ]
}
